rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveAdmin() {
      return signedIn() && userDoc().role == 'admin' && userDoc().active == true;
    }

    function isActiveStaff() {
      return signedIn() && userDoc().role == 'staff' && userDoc().active == true;
    }

    // ---- users ----
    match /users/{uid} {
      // A brand-new staff account writes its own profile doc immediately
      // after Admin creates it via the secondary-app signup flow; it may
      // only ever create itself as an active, non-admin staff member.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'staff'
        && request.resource.data.active == true;

      allow read: if signedIn() && (request.auth.uid == uid || isActiveAdmin() || isActiveStaff());
      allow update, delete: if isActiveAdmin();
    }

    // ---- students ----
    // Read is company-wide for any active staff member (Dashboard/Reports
    // show the same totals to Staff as to Admin). Profile edits/creation stay
    // scoped to Admin or the staff member who added that particular student;
    // recording a payment (amountPaid/feeStatus only) is company-wide too,
    // same as read, see the `update` rule below.
    match /students/{studentId} {
      allow read: if isActiveAdmin() || isActiveStaff();

      allow create: if isActiveAdmin()
        || (isActiveStaff() && request.resource.data.addedBy == request.auth.uid);

      // Full profile edits (name, address, course, totalAmount, ...) stay
      // scoped to Admin or the staff member who added that student. Payment
      // recording only ever touches amountPaid/feeStatus/updatedAt and is
      // allowed for any active staff, matching the company-wide read access
      // above (FeeService.recordPayment needs this to update the student's
      // running total from any staff account, not just the one that added
      // the student).
      allow update: if request.resource.data.addedBy == resource.data.addedBy
        && (
          isActiveAdmin()
          || (isActiveStaff() && resource.data.addedBy == request.auth.uid)
          || (isActiveStaff() && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['amountPaid', 'feeStatus', 'updatedAt']))
        );

      // Deleting a student now cascades to their fees/activityLogs (see
      // FeeService/StudentService), which only Admin may delete below, so
      // student deletion itself is Admin-only too — otherwise a Staff-driven
      // delete would leave orphaned fee/log records behind again.
      allow delete: if isActiveAdmin();
    }

    // ---- fees (append-only ledger; the one exception is Admin cascading a
    // student deletion, or cleaning up already-orphaned records, per
    // StudentService.deleteStudent / FeeService.deleteOrphanedFeeRecords) ----
    match /fees/{feeId} {
      allow read: if isActiveAdmin() || isActiveStaff();

      // Any active staff can record a payment for any student, matching the
      // company-wide read access on students above (not just students they
      // personally added).
      allow create: if request.resource.data.recordedBy == request.auth.uid
        && (isActiveAdmin() || isActiveStaff());

      allow update: if false;
      allow delete: if isActiveAdmin();
    }

    // ---- activityLogs (append-only audit trail; Admin-only delete, same
    // cascade/cleanup exception as fees above) ----
    match /activityLogs/{logId} {
      allow read: if isActiveAdmin() || isActiveStaff();
      allow create: if signedIn() && request.resource.data.performedBy == request.auth.uid;
      allow update: if false;
      allow delete: if isActiveAdmin();
    }
  }
}
